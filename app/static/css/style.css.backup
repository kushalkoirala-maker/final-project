:root {
  --bg-app: #edf3f8;
  --bg-panel: rgba(255, 255, 255, 0.92);
  --bg-sidebar: linear-gradient(180deg, #0b1726 0%, #14243a 100%);
  --border-soft: rgba(148, 163, 184, 0.18);
  --text-main: #102033;
  --text-muted: #6b7b8f;
  --shadow-soft: 0 24px 60px rgba(15, 23, 42, 0.10);
  --terminal-bg: #04150b;
  --terminal-text: #54ff9f;
  --sidebar-width: 260px;
}

body {
  font-family: "Space Grotesk", Arial, sans-serif;
  background:
    radial-gradient(circle at top right, rgba(49, 130, 206, 0.12), transparent 30%),
    linear-gradient(180deg, #f6fbff 0%, var(--bg-app) 100%);
  color: var(--text-main);
  overflow-x: hidden;
}

.app-shell {
  min-height: 100vh;
  width: 100%;
  ovelayout {
  display: flex;
  width: 100%;
  min-height: 100vh;
}

.app-sidebar {
  position: fixed;
  inset: 0 auto 0 0;
  width: var(--sidebar-width);
  padding: 2rem 1.25rem;
  background: var(--bg-sidebar);
  color: #f8fafc;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 20px 60px rgba(2, 8, 23, 0.35);
  z-index: 1030;
  overflow-y: auto;
  max-height: 100vhn: column;
  justify-content: space-between;
  box-shadow: 0 20px 60px rgba(2, 8, 23, 0.35);
  z-index: 1030;
}

.brand-mark {
  display: flex;
  gap: 0.95rem;
  align-items: center;
}

.brand-icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #2b6cb0, #38b2ac);
  font-size: 1.35rem;
}

.brand-kicker,
.page-eyebrow,
.panel-kicker,
.metric-label {
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-size: 0.74rem;
}

.brand-kicker {
  color: #8eb7ff;
}

.brand-title {
  font-size: 1.1rem;
  font-weight: 700;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  padding: 0.9rem 1rem;
  border-radius: 14px;
  color: rgba(241, 245, 249, 0.82);
  text-decoration: none;
  transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
}

.sidebar-link:hover,
.sidebar-link.active {
  color: #fff;
  background: rgba(96, 165, 250, 0.16);
  transform: translateX(4px);
}

.sidebar-link i {
  color: rgba(191, 219, 254, 0.68);
  transition: color 0.2s ease, transform 0.2s ease;
}backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1029;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.sidebar-backdrop.show {
  opacity: 1;
  visibility: visible;
}

.sidebar-

.sidebar-link.active i,
.sidebar-link:hover i {
  color: #7dd3fc;
  transform: scale(1.04);
}

.sidebar-user {
  padding: 1rem;
  border-radius: 18px;
  background: rgba(15, 23, 42, 0.45);
  border: 1px solid rgba(148, 163, 184, 0.18);
}
flex: 1;
  width: calc(100% - var(--sidebar-width));
  margin-left: var(--sidebar-width);
  overflow-x: hidden;
}

.main-content {
  width: 100%;
  height: 100%;
  padding: 2rem;
  overflow-y: auto;
  box-sizing: border-box
.app-main {
  width: 100%;
}

.main-content {
  width: 100%;
  margin-left: 250px;
  padding: 2rem;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.page-eyebrow,
.panel-kicker {
  color: #4f6d8f;
}

.page-title {
  font-size: clamp(1.8rem, 3vw, 2.7rem);
  font-weight: 700;
}

.page-intro {
  padding: 0.5rem 0 0.25rem;
}

.panel-card,
.metric-card,
.card {
  background: var(--bg-panel);
  border: 1px solid var(--border-soft);
  box-shadow: var(--shadow-soft);
  border-radius: 24px;
}

.panel-card,
.card {
  padding: 1.5rem;
}

.panel-title {
  font-size: 1.2rem;
  font-weight: 700;
}

.metric-card {
  position: relative;
  overflow: hidden;
  padding: 1.4rem;
  min-height: 160px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metric-card::after {
  content: "";
  position: absolute;
  inset: auto -24px -32px auto;
  width: 120px;
  height: 120px;
  border-radius: 999px;
  opacity: 0.22;
}

.metric-primary::after { background: #2563eb; }
.metric-success::after { background: #16a34a; }
.metric-danger::after { background: #dc2626; }
.metric-warning::after { background: #f59e0b; }

.metric-value {
  font-size: 2.5rem;
  font-weight: 700;
}

.metric-footnote {
  color: var(--text-muted);
}

.flash-wrap {
  margin-bottom: 1rem;
}

.flash {
  padding: 1rem 1.1rem;
  border-radius: 16px;
  margin-bottom: 0.75rem;
  border: 1px solid transparent;
  box-shadow: var(--shadow-soft);
}

.flash.danger { background: #fff0f0; border-color: #fecaca; }
.flash.success { background: #effdf4; border-color: #bbf7d0; }
.flash.info { background: #eff6ff; border-color: #bfdbfe; }

.table-darkless {
  --bs-table-bg: transparent;
  --bs-table-striped-bg: rgba(148, 163, 184, 0.06);
  --bs-table-hover-bg: rgba(37, 99, 235, 0.05);
}

.table-darkless thead th {
  color: var(--text-muted);
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  border-bottom-width: 1px;
}

.table-darkless td,
.table-darkless th,
table td,
table th {
  padding: 0.95rem 0.75rem;
  vertical-align: middle;
}

table {
  width: 100%;
  border-collapse: collapse;
}

.alert-tile {
  display: flex;
  gap: 0.9rem;
  align-items: flex-start;
  padding: 1rem;
  border-radius: 18px;
  background: rgba(248, 250, 252, 0.8);
  border: 1px solid rgba(148, 163, 184, 0.16);
}

.job-history-item {
  display: flex;
  gap: 1rem;
  padding: 1.1rem;
  border-radius: 18px;
  background: rgba(248, 250, 252, 0.92);
  border: 1px solid rgba(148, 163, 184, 0.14);
}

.job-status-icon {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: rgba(15, 23, 42, 0.04);
  flex: 0 0 auto;
  font-size: 1.1rem;
}

.alert-list-item {
  background: transparent;
  border: 0;
  border-left: 4px solid transparent;
  padding-left: 1rem;
}

.alert-list-item.severity-crit {
  border-left-color: #dc2626;
}

.alert-list-item.severity-warn {
  border-left-color: #f59e0b;
}

.alert-list-item.severity-info {
  border-left-color: #2563eb;
}

.severity-info { background: #dbeafe; color: #1d4ed8; }
.severity-warn { background: #fef3c7; color: #b45309; }
.severity-crit { background: #fee2e2; color: #b91c1c; }

.status-pending { background: #e2e8f0; color: #334155; }
.status-running { background: #dbeafe; color: #1d4ed8; }
.status-success { background: #dcfce7; color: #15803d; }
.status-failed { background: #fee2e2; color: #b91c1c; }

.badge {
  font-weight: 700;
}

.terminal-modal-shell {
  background: #06140d;
  color: #f8fafc;
  border: 1px solid rgba(84, 255, 159, 0.18);
}

.terminal-body,
.terminal-view,
.output-box {
  font-family: "JetBrains Mono", monospace;
  white-space: pre-wrap;
  max-height: 520px;
  overflow: auto;
  padding: 1rem;
  border-radius: 18px;
  background: var(--terminal-bg);
  color: var(--terminal-text);
  border: 1px solid rgba(84, 255, 159, 0.15);
  position: relative;
  background-image:
    linear-gradient(rgba(84, 255, 159, 0.06) 1px, transparent 1px),
    linear-gradient(180deg, rgba(4, 21, 11, 0.96), rgba(4, 21, 11, 0.98));
  background-size: 100% 3px, 100% 100%;
}

.output-box {
  background: #f8fafc;
  color: #1e293b;
  border-color: #dbe4f0;
  background-image: none;
.muted,
.hint,
.text-secondary {
  color: var(--text-muted) !important;
}

input,
select,
button,
textarea {
  border-radius: 14px !important;
}

/* Responsive: tablets and smaller screens */
@media (max-width: 991.98px) {
  .app-layout {
    flex-direction: column;
  }

  .app-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-width);
    height: 100vh;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 1031;
  }

  .app-sidebar.show {
    transform: translateX(0);
  }

  .app-main {
    width: 100%;
    margin-left: 0;
    overflow-x: hidden;
  }

  .main-content {
    padding: 1.25rem;
    width: 100%;
  }

  .page-header {
    flex-direction: column;
    align-items: flex-start;
  }
}

/* Mobile optimization */
@media (max-width: 575.98px) {
  .main-content {
    padding: 1rem;
  }

  .page-title {
    font-size: clamp(1.3rem, 2vw, 1.8rem)
.muted,
.hint,
.text-secondary {
  color: var(--text-muted) !important;
}

input,
select,
button,
textarea {
  border-radius: 14px !important;
}

@media (max-width: 991.98px) {
  .app-sidebar {
    position: static;
    width: auto;
    border-radius: 0 0 24px 24px;
  }

  .app-main {
    margin-left: 0;
    padding: 1.25rem;
  }

  .page-header {
    flex-direction: column;
    align-items: flex-start;
  }
}
